# ─────────────────────────────────────────────────────────────────────────────
# GARVIS / garvis-living-ui — safe .gitignore (Vite + React + TypeScript + Node)
# Phase 0 foundation. Keeps node_modules, build output, logs, screenshots, env
# files, CodeGraph index, and local Claude artifacts out of version control.
# ─────────────────────────────────────────────────────────────────────────────

# Dependencies
node_modules/
.pnp
.pnp.js
.npm/
.yarn/

# Build output / bundler artifacts
dist/
dist-ssr/
build/
out/
.vite/
*.tsbuildinfo
vite.config.ts.timestamp-*

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment / secrets (NEVER commit) — keep an example file if one is added
.env
.env.*
!.env.example
*.pem
*.key

# Screenshots & visual-proof captures (dev artifacts at repo root)
/screenshots/
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp
# (public/ assets are kept tracked — only root-level captures are ignored)

# Test / tooling output
coverage/
test-results/
playwright-report/
.playwright/
blob-report/

# CodeGraph index (created on demand by the user, never auto-committed)
.codegraph/

# Local Claude Code artifacts (machine-local; CLAUDE.md & AGENTS.md ARE tracked)
.claude/
CLAUDE.local.md
.mcp.local.json

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
desktop.ini
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.local
