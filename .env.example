# GARVIS Local Environment — Predator (Ubuntu WSL2)
# Copy to .env and customize

# PostgreSQL
POSTGRES_USER=garvis
POSTGRES_PASSWORD=garvis_local
POSTGRES_DB=garvis
POSTGRES_HOST=garvis-postgres
POSTGRES_PORT=5432

# Ollama
OLLAMA_HOST=http://garvis-ollama:11434
OLLAMA_DEFAULT_MODEL=llama3.1

# GARVIS
GARVIS_ENV=local
LOG_LEVEL=INFO
GOVERNANCE_SCHEMAS_PATH=/app/governance/schemas
API_PORT=8000

# Dashboard
DASHBOARD_ENABLED=true
